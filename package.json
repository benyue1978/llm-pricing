{
  "name": "llm-pricing",
  "version": "0.1.0",
  "description": "LLM pricing registry with a TypeScript CLI and static web dashboard.",
  "private": true,
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "llm-pricing": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "update": "node dist/cli/index.js update",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:ci": "vitest run",
    "test:e2e": "playwright test",
    "web:dev": "serve . -l 4173"
  },
  "keywords": [
    "llm",
    "pricing",
    "registry",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "playwright": "^1.50.0",
    "serve": "^14.2.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.4"
  }
}
